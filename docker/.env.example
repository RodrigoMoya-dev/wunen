# Copia este archivo a .env y completa los valores

# PostgreSQL
POSTGRES_DB=wunen
POSTGRES_USER=wunen
POSTGRES_PASSWORD=wunen_secret_2024

# Anthropic / Claude API (obtener en console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Frontend (URL del backend vista desde el navegador)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Entorno
ENVIRONMENT=development

# Telegram (para notificaciones via n8n)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp (Baileys) ───────────────────────────────────────────────────────
# Número de teléfono sin el + (ej: 56962075019 para +56962075019)
WHATSAPP_DEFAULT_PHONE=56962075019
WHATSAPP_PAIRING_PHONE=56962075019

# ── Gmail (para postulaciones FindJobIT vía email) ───────────────────────────
# 1. Ir a: https://myaccount.google.com/apppasswords
# 2. Crear contraseña de aplicación: "Otro" → "Wunen"
# 3. Copiar los 16 caracteres (sin espacios)
GMAIL_USER=rodrigo.alex.moya@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_FROM_NAME=Rodrigo Moya

# Score mínimo (0-100) para auto-postular en FindJobIT (default: 50)
FINDJOBIT_MIN_SCORE=50
